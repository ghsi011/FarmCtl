#!/usr/bin/env bash

set -euo pipefail

# Find staged Dart files only
mapfile -t STAGED_DART < <(git diff --cached --name-only --diff-filter=ACM -- '*.dart')

# Nothing to do
if [ "${#STAGED_DART[@]}" -eq 0 ]; then
  exit 0
fi

# Choose formatter
format_cmd=""
if command -v dart >/dev/null 2>&1; then
  format_cmd="dart format -o write"
elif command -v flutter >/dev/null 2>&1; then
  format_cmd="flutter format"
else
  echo "Pre-commit: dart or flutter not found in PATH; cannot run formatter." >&2
  exit 1
fi

# Run formatter on staged Dart files (working tree), then require re-stage
${format_cmd} "${STAGED_DART[@]}" >/dev/null

# If formatter changed any of those files relative to the index, block commit
if ! git diff --quiet -- "${STAGED_DART[@]}"; then
  echo "Pre-commit: Formatting applied to Dart files. Please review and 'git add' the changes, then commit again." >&2
  # Show which files changed
  git diff --name-only -- "${STAGED_DART[@]}" >&2 || true
  exit 1
fi

exit 0


